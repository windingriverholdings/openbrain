[Unit]
Description=OpenBrain Slack Bot
After=network.target postgresql.service

[Service]
Type=simple
WorkingDirectory=%h/repos/my-openbrain

EnvironmentFile=%h/repos/my-openbrain/.env

ExecStart=%h/repos/my-openbrain/bin/openbrain-slack

Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=openbrain-slack

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/repos/my-openbrain

[Install]
WantedBy=default.target
