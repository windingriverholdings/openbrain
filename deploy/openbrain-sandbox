#!/bin/sh
# openbrain - file bridge client for OpenBrain
# Writes /workspace/openbrain-request.json, waits for /workspace/openbrain-response.json
# No wget, curl, python, or network access required — only file read/write.

WORKSPACE=/workspace
REQ="$WORKSPACE/openbrain-request.json"
RESP="$WORKSPACE/openbrain-response.json"
TIMEOUT=10  # seconds to wait for host daemon

CMD="$1"
shift 2>/dev/null || true

# Clean up any stale files from prior run
rm -f "$REQ" "$RESP"

case "$CMD" in
    search)
        QUERY="$1"; TOP_K="${2:-5}"
        printf '{"cmd":"search","query":"%s","top_k":%s}' \
            "$(echo "$QUERY" | sed 's/"/\\"/g')" "$TOP_K" > "$REQ"
        ;;
    capture)
        CONTENT="$1"; TYPE="${2:-note}"; SOURCE="${3:-openclaw}"
        printf '{"cmd":"capture","content":"%s","thought_type":"%s","source":"%s"}' \
            "$(echo "$CONTENT" | sed 's/"/\\"/g')" "$TYPE" "$SOURCE" > "$REQ"
        ;;
    stats)
        printf '{"cmd":"stats"}' > "$REQ"
        ;;
    review)
        DAYS="${1:-7}"
        printf '{"cmd":"review","days":%s}' "$DAYS" > "$REQ"
        ;;
    *)
        echo "Usage: openbrain <search|capture|stats|review> [args]"
        echo ""
        echo "  openbrain search \"query\" [top_k]"
        echo "  openbrain capture \"content\" [thought_type] [source]"
        echo "  openbrain stats"
        echo "  openbrain review [days]"
        exit 1
        ;;
esac

# Wait for host daemon to process and write response
i=0
while [ $i -lt $((TIMEOUT * 10)) ]; do
    if [ -f "$RESP" ]; then
        cat "$RESP"
        echo
        rm -f "$RESP"
        exit 0
    fi
    sleep 0.1
    i=$((i + 1))
done

echo '{"ok":false,"error":"timeout: openbrain-watchd not responding — is it running on the host?"}' >&2
rm -f "$REQ"
exit 1
