[Unit]
Description=OpenBrain sandbox file bridge daemon
After=network.target postgresql.service
PartOf=openbrain-web.service

[Service]
Type=simple
WorkingDirectory=%h/repos/openbrain

ExecStart=%h/repos/openbrain/bin/openbrain-watchd

EnvironmentFile=%h/repos/openbrain/.env

Restart=on-failure
RestartSec=5

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/repos/openbrain %h/.openclaw

[Install]
WantedBy=default.target
