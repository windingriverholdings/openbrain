# OpenBrain Environment Configuration
# Copy to .env and fill in values

# ── Database ─────────────────────────────────────────────
OPENBRAIN_DB_HOST=localhost
OPENBRAIN_DB_PORT=5432
OPENBRAIN_DB_NAME=openbrain
OPENBRAIN_DB_USER=openbrain
OPENBRAIN_DB_PASSWORD=change_me

# ── Embedding ─────────────────────────────────────────────
# Default: BAAI/bge-small-en-v1.5 (fast CPU, 384 dims, local)
OPENBRAIN_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
OPENBRAIN_EMBEDDING_DIM=384

# ── Retrieval ─────────────────────────────────────────────
OPENBRAIN_SEARCH_TOP_K=10
OPENBRAIN_SEARCH_SCORE_THRESHOLD=0.35

# ── Telegram Bot (work branch) ────────────────────────────
# Create a bot via @BotFather on Telegram
OPENBRAIN_TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get your user ID from @userinfobot on Telegram
OPENBRAIN_TELEGRAM_ALLOWED_USER_ID=your_numeric_user_id

# ── Slack Bot ─────────────────────────────────────────────
# Socket Mode — no public URL required, runs fully local
# Bot token: OAuth & Permissions → Bot Token (xoxb-...)
OPENBRAIN_SLACK_BOT_TOKEN=xoxb-your-bot-token
# App token: Socket Mode → App-Level Token with connections:write scope (xapp-...)
OPENBRAIN_SLACK_APP_TOKEN=xapp-your-app-token
# Your Slack user ID: click your name → Profile → ⋮ → Copy member ID (e.g. U012AB3CD)
OPENBRAIN_SLACK_ALLOWED_USER_ID=U012AB3CD

# ── Web UI ────────────────────────────────────────────────
# Local only — accessible at http://mybrain.local:10203
OPENBRAIN_WEB_HOST=127.0.0.1
OPENBRAIN_WEB_PORT=10203
# TODO(tailscale): Change WEB_HOST to 0.0.0.0 when exposing via Tailscale + Caddy

# ── MCP HTTP Transport ───────────────────────────────────
# Enable the HTTP-based MCP transport (Streamable HTTP + SSE)
OPENBRAIN_MCP_HTTP_ENABLED=false
# Bearer token for MCP HTTP authentication (min 32 chars)
# OPENBRAIN_MCP_AUTH_TOKEN=your-secret-token-at-least-32-chars

# ── OAuth 2.0 (Claude.ai MCP Connector) ─────────────────
# Required for Claude.ai's remote MCP connector.
# Claude.ai sends client_id + client_secret to obtain a bearer token.
# OPENBRAIN_OAUTH_CLIENT_ID=your-oauth-client-id
# OPENBRAIN_OAUTH_CLIENT_SECRET=your-oauth-client-secret-min-32-chars
# Issuer URL (must match your public-facing domain)
# OPENBRAIN_OAUTH_ISSUER=https://openbrain.wr-s.net

# ── LLM Extraction (Phase 3) ────────────────────────────
# Provider: "ollama" (local), "claude" (API), or "none" (disabled)
OPENBRAIN_EXTRACT_PROVIDER=ollama
# Primary model: used for long/complex text and corrections
OPENBRAIN_EXTRACT_MODEL=gemma3
# Fast model: used for short/simple text (leave empty to always use primary)
OPENBRAIN_EXTRACT_MODEL_FAST=llama3.2:1b
# Char threshold: text longer than this uses the primary model (default 500)
OPENBRAIN_EXTRACT_FAST_THRESHOLD=500
# Ollama server URL (default: http://localhost:11434)
OPENBRAIN_OLLAMA_BASE_URL=http://localhost:11434
# Anthropic API key (only needed for claude provider)
# OPENBRAIN_ANTHROPIC_API_KEY=sk-ant-...
