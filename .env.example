# OpenBrain Environment Configuration
# Copy to .env and fill in values

# ── Database ─────────────────────────────────────────────
OPENBRAIN_DB_HOST=localhost
OPENBRAIN_DB_PORT=5432
OPENBRAIN_DB_NAME=openbrain
OPENBRAIN_DB_USER=openbrain
OPENBRAIN_DB_PASSWORD=change_me

# ── Embedding ─────────────────────────────────────────────
# Default: BAAI/bge-small-en-v1.5 (fast CPU, 384 dims, local)
OPENBRAIN_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
OPENBRAIN_EMBEDDING_DIM=384

# ── Retrieval ─────────────────────────────────────────────
OPENBRAIN_SEARCH_TOP_K=10
OPENBRAIN_SEARCH_SCORE_THRESHOLD=0.35

# ── Telegram Bot (work branch) ────────────────────────────
# Create a bot via @BotFather on Telegram
OPENBRAIN_TELEGRAM_BOT_TOKEN=your_bot_token_here
# Get your user ID from @userinfobot on Telegram
OPENBRAIN_TELEGRAM_ALLOWED_USER_ID=your_numeric_user_id

# ── Web UI ────────────────────────────────────────────────
# Local only — accessible at http://mybrain.local:10203
OPENBRAIN_WEB_HOST=127.0.0.1
OPENBRAIN_WEB_PORT=10203
# TODO(tailscale): Change WEB_HOST to 0.0.0.0 when exposing via Tailscale + Caddy
